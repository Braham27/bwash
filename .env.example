# ============================================
# BWash Environment Variables
# ============================================

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/bwash?sslmode=require

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Notifications (optional)
RESEND_API_KEY=re_xxxxx

# Business Config
NEXT_PUBLIC_BUSINESS_NAME=BWash
NEXT_PUBLIC_BUSINESS_PHONE=+1234567890
NEXT_PUBLIC_BUSINESS_EMAIL=info@bwash.com
NEXT_PUBLIC_WHATSAPP_NUMBER=+1234567890
